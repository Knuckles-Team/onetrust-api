# ─── OneTrust connection ───────────────────────────────────────────────
# Tenant host URL (overrides ONETRUST_REGION). e.g. https://acme.my.onetrust.com
ONETRUST_URL=
# Or pick a shared regional pod: us, eu, de, uk, au, ca, fr, in, jp, trial, uat ...
ONETRUST_REGION=us

# ─── Authentication (use ONE of the two) ───────────────────────────────
# 1) Pre-minted OAuth2 bearer token (Global Settings > Access Management > Credentials)
ONETRUST_TOKEN=
# 2) OAuth2 client-credentials (exchanged at /api/access/v1/oauth/token)
ONETRUST_CLIENT_ID=
ONETRUST_CLIENT_SECRET=

# ─── Optional service hosts ────────────────────────────────────────────
# Consent transaction / privacy-portal host (consent_receipts, universal_consent ...)
ONETRUST_CONSENT_URL=
# On-prem Data Discovery worker-node host
ONETRUST_WORKER_URL=

# ─── HTTP behaviour ────────────────────────────────────────────────────
ONETRUST_SSL_VERIFY=True

# ─── MCP transport / auth (agent-utilities) ────────────────────────────
FASTMCP_LOG_LEVEL=INFO
# TRANSPORT=stdio
# AUTH_TYPE=none
